# Database connection string (PostgreSQL)
DATABASE_URI=postgres://payload:payload@localhost:5432/payload
# DATABASE_URI=postgres://default:xxxxx@xxx-xxx-xxx.postgres.vercel-storage.com:5432/verceldb
# Used to encrypt JWT tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://thewhite.local:3000

# Admin user credentials (used by seed script)
ADMIN_EMAIL=admin@thewhite.vn
ADMIN_PASSWORD=TheWhite@2024
ADMIN_NAME=Admin

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=


# Gemini AI (get free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# GCP (project for Cloud Run + Secret Manager + media bucket)
GCP_PROJECT_ID=
GCP_REGION=asia-southeast1

# Payload media bucket — when set, Payload writes uploads to this GCS bucket
# via @payloadcms/storage-gcs instead of the local filesystem. Leave empty in
# local dev to use `public/media/` + `public/size-charts/` static dirs.
PAYLOAD_MEDIA_BUCKET=

# Resend (transactional email). Get key at https://resend.com
RESEND_API_KEY=

# Gate: set to "true" only for initial bootstrap; never in production runtime
ALLOW_SEED_ENDPOINT=
